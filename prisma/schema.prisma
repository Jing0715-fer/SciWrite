// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String      @id @default(cuid())
  title       String
  topic       String
  description String?
  field       String? // research field, e.g. structural-biology, genomics
  journalTemplate String? // e.g. nature, cell, science, jbc, plos, ieee
  status      String      @default("active") // active, archived
  paragraphs  Paragraph[]
  articles    Article[]
  dataSources DataSource[]
  references  Reference[]
  userData    UserData[]
  relationships RelationshipAnalysis[]
  conversations ConversationSession[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Paragraph {
  id               String              @id @default(cuid())
  projectId        String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  content          String              // markdown content with inline citations like [PMID:123]
  format           String              @default("background") // background, intro, methods, results, discussion, conclusion, abstract
  scenario         String              @default("literature-review") // literature-review, protein-structure, sequence-analysis, mechanism, comparative, clinical, custom
  status           String              @default("draft") // draft, annotated, revising, revised, finalized
  order            Int                 @default(0)
  wordCount        Int                 @default(0)
  annotations      Annotation[]
  references       Reference[]
  articleParagraph ArticleParagraph[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([projectId])
}

model Annotation {
  id           String    @id @default(cuid())
  paragraphId  String
  paragraph    Paragraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  startOffset  Int       @default(0)
  endOffset    Int       @default(0)
  selectedText String    @default("")
  comment      String
  type         String    @default("comment") // comment, revise-request, question, highlight, praise
  severity     String    @default("info") // info, warning, critical
  resolved     Boolean   @default(false)
  aiResponse   String?
  createdAt    DateTime  @default(now())

  @@index([paragraphId])
}

model Reference {
  id            String     @id @default(cuid())
  paragraphId   String?
  paragraph     Paragraph? @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type          String     // pubmed, uniprot, pdb, ncbi, blast, web, manual
  externalId    String?
  title         String
  authors       String?
  journal       String?
  year          String?
  url           String?
  doi           String?
  abstract      String?
  citationKey   String?
  citationOrder Int?       // 0-based index within the paragraph, matching [n] citation order (1 = index 0)
  createdAt     DateTime   @default(now())

  @@index([paragraphId])
  @@index([projectId])
}

model DataSource {
  id         String   @id @default(cuid())
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source     String   // rcsb, uniprot, pubmed, ncbi, blast, web, manual
  query      String
  rawJson    String
  summary    String?
  title      String?
  externalId String?
  url        String?
  pinned     Boolean  @default(false)
  // Enhanced metadata
  authors    String?
  journal    String?
  year       String?
  doi        String?
  abstract   String?
  keywords   String?  // JSON array
  extra      String?  // JSON object for source-specific fields (e.g. resolution, method, gene)
  createdAt  DateTime @default(now())

  @@index([projectId])
}

model Article {
  id               String              @id @default(cuid())
  projectId        String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title            String
  abstract         String?
  content          String
  journalTemplate String?
  articleParagraph ArticleParagraph[]
  reviews          Review[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([projectId])
}

model ArticleParagraph {
  id          String    @id @default(cuid())
  articleId   String
  article     Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  paragraphId String
  paragraph   Paragraph @relation(fields: [paragraphId], references: [id], onDelete: Cascade)
  order       Int
  section     String?

  @@index([articleId])
}

model Review {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  round       Int      @default(1)
  // Structured scores (0-10 each)
  scoreNovelty      Float?
  scoreSignificance Float?
  scoreClarity      Float?
  scoreMethodology  Float?
  scoreCitations     Float?
  scoreOverall      Float?
  // Qualitative verdict
  verdict     String   // accept | minor-revision | major-revision | reject
  summary     String   // AI-generated review summary
  strengths   String   // JSON array of strengths
  weaknesses  String   // JSON array of weaknesses
  suggestions String   // JSON array of revision suggestions
  // Iteration tracking
  revisedContent String? // the revised content after acting on this review
  createdAt   DateTime @default(now())

  @@index([articleId])
}

// User-provided data: images, tables, text descriptions used in Results writing
model UserData {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String   // image, table, text
  title       String
  description String?  // user-provided caption/description
  filePath    String?  // for uploaded images (relative path under /upload)
  data        String?  // JSON: for tables (rows/cols) or structured data
  createdAt   DateTime @default(now())

  @@index([projectId])
}

// Source relationship analysis (persisted)
model RelationshipAnalysis {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  summary     String
  themes      String   // JSON array
  edges       String   // JSON array
  nodes       String   // JSON array
  keyInsights String   // JSON array
  contradictions String // JSON array
  createdAt   DateTime @default(now())

  @@index([projectId])
}

// LLM conversation session — maintains context across multiple AI tasks within a project
// so that gather → curate → plan → generate → compose → review can share context
model ConversationSession {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskType    String   // gather, curate, relationships, plan, generate, compose, review, write, outline, revise
  role        String   // system | user | assistant
  content     String   // the message content
  metadata    String?  // JSON: { sectionTitle, wordCount, temperature, etc. }
  tokenEstimate Int   @default(0) // rough token estimate for context window management
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([projectId, taskType])
}
